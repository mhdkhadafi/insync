---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const allCategories = [...new Set(allPosts.flatMap(p => p.data.categories ?? []))];
  return allCategories.map(category => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.props;
const allPosts = await getCollection('blog');
const filteredPosts = allPosts
  .filter(p => p.data.categories?.includes(category))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allCategories = [...new Set(allPosts.flatMap(p => p.data.categories ?? []))].sort();
---

<BaseLayout title={`${category} — Stories`} description={`IN SYNC stories tagged ${category}`}>
  <div class="container">
    <section class="blog-header">
      <h1 class="blog-header__title">{category}</h1>
    </section>

    <nav class="category-filter" aria-label="Filter by category">
      <a href="/blog" class="category-filter__link">All</a>
      {allCategories.map(cat => (
        <a
          href={`/blog/category/${cat}`}
          class:list={['category-filter__link', { 'category-filter__link--active': cat === category }]}
        >{cat}</a>
      ))}
    </nav>

    <div class="blog-list">
      {filteredPosts.map(post => (
        <BlogCard
          title={post.data.title}
          date={post.data.date}
          author={post.data.author}
          excerpt={post.data.excerpt}
          slug={post.slug}
          image={post.data.image}
          categories={post.data.categories}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .blog-header { padding: 80px 0 40px; }
  .blog-header__title { font-family: var(--font-heading); font-size: var(--font-size-xxl); }

  .category-filter { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 48px; justify-content: center; }
  .category-filter__link { font-size: 12px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--color-text-light); transition: color 0.2s; }
  .category-filter__link:hover { color: var(--color-text); text-decoration: underline; }
  .category-filter__link--active { color: var(--color-text); text-decoration: underline; }

  .blog-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px; padding-bottom: 80px; }

  @media (max-width: 768px) {
    .blog-list { grid-template-columns: 1fr; }
  }
</style>
